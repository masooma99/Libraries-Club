<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create a book</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #2c3e50 0%, #000000 100%);
        min-height: 100vh;
        padding: 20px;
      }

      h1 {
        text-align: center;
        color: white;
        font-size: 2.5rem;
        margin-bottom: 30px;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
      }

      h2 {
        text-align: center;
        color: white;
        font-size: 2rem;
        margin-bottom: 30px;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
      }

      h4 {
        color: rgb(37, 35, 35);
        margin: 15px 0 10px 0;
        font-size: 1.1rem;
      }

      .head {
        text-align: center;
        margin-bottom: 30px;
      }

      .head a {
        display: inline-block;
        color: white;
        text-decoration: none;
        background: #ff6b6b;
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: bold;
        transition: background 0.3s;
      }

      .head a:hover {
        background: #ff5252;
      }

      form {
        max-width: 500px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
      }

      input[type="text"],
      input[type="number"] {
        width: 100%;
        padding: 12px 15px;
        margin: 10px 0;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 16px;
        outline: none;
        transition: border-color 0.3s;
      }

      input[type="text"]:focus,
      input[type="number"]:focus {
        border-color: #ff6b6b;
      }

      input[type="radio"] {
        margin: 10px 10px 10px 0;
      }

      label {
        color: #333;
        font-size: 16px;
        margin-right: 15px;
      }

      button {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #ff6b6b, #ff5252);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
        transition:
          transform 0.3s,
          box-shadow 0.3s;
        margin-top: 20px;
      }

      button:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255, 107, 107, 0.4);
      }

      @media (max-width: 768px) {
        h1 {
          font-size: 1.8rem;
        }

        h2 {
          font-size: 1.5rem;
        }

        form {
          padding: 25px;
          margin: 0 15px;
        }
      }
    </style>
  </head>
  <body>
    <div class="head">
      <h1>Libraries Club</h1>
      <a href="/home">Home</a>
    </div>
    <h2>Create a Book</h2>
    <form action="/books/create" method="POST">
      <input type="text" name="title" placeholder="Title" required /><br />
      <input
        type="text"
        name="description"
        placeholder="Description"
        required
      />
      <br />

      <input type="text" name="picture" placeholder="Picture" required />
      <br />

      <h4>Genre:</h4>
      <input type="radio" id="fantasy" name="genre" value="Fantasy" />
      <label for="fantasy">Fantasy</label><br />

      <input type="radio" id="romance" name="genre" value="Romance" />
      <label for="romance">Romance</label><br />

      <input type="radio" id="horror" name="genre" value="Horror" />
      <label for="horror">Horror</label><br />

      <input type="radio" id="history" name="genre" value="History" />
      <label for="history">History</label><br />

      <input type="radio" id="crime" name="genre" value="Crime" />
      <label for="crime">Crime</label><br />

      <input type="radio" id="Psychology" name="genre" value="Psychology" />
      <label for="Psychology">Psychology</label><br />
      <br />
      <input
        type="number"
        name="numOfPages"
        placeholder="num Of Pages"
        required
      />
      <br />
      <input type="text" name="author" placeholder="Author" required /><br />
      <input
        type="number"
        name="numOfCopies"
        placeholder="number Of Copies"
        required
      />
      <br />
      <br />
      <button type="submit">Create</button>
    </form>
  </body>
</html>
