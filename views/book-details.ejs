<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= book.title %></title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        min-height: 100vh;
        padding: 40px 20px;
      }

      .container {
        max-width: 1000px;
        margin: 0 auto;
        background: #1a1a2e;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        overflow: hidden;
        animation: fadeIn 0.6s ease-out;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      .back-button {
        display: inline-block;
        padding: 12px 24px;
        background: #0f3460;
        color: #e0e0e0;
        text-decoration: none;
        border-radius: 8px;
        margin: 20px 20px 0 20px;
        transition: all 0.3s ease;
        font-weight: 500;
      }

      .back-button:hover {
        background: #16213e;
        color: white;
        transform: translateX(-5px);
      }

      .book-content {
        display: flex;
        flex-wrap: wrap;
        padding: 40px;
        gap: 40px;
      }

      .book-image-section {
        flex: 1;
        min-width: 250px;
        text-align: center;
      }

      .book-image-section img {
        max-width: 100%;
        height: auto;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        transition: transform 0.3s ease;
      }

      .book-image-section img:hover {
        transform: scale(1.05);
      }

      .book-info-section {
        flex: 2;
        min-width: 300px;
      }

      h1 {
        font-size: 2.5em;
        color: #e0e0e0;
        margin-bottom: 20px;
        border-bottom: 3px solid #0f3460;
        padding-bottom: 10px;
        display: inline-block;
      }

      .info-group {
        margin: 20px 0;
        padding: 15px;
        background: #16213e;
        border-radius: 10px;
        transition: all 0.3s ease;
      }

      .info-group:hover {
        background: #1a1a3e;
        transform: translateX(5px);
      }

      .info-label {
        font-weight: bold;
        color: #4a9eff;
        font-size: 1.1em;
        display: inline-block;
        min-width: 100px;
      }

      .info-value {
        color: #b0b0b0;
        font-size: 1.05em;
      }

      .description {
        margin-top: 30px;
        padding: 20px;
        background: #16213e;
        border-radius: 10px;
        border-left: 4px solid #4a9eff;
      }

      .description .info-label {
        display: block;
        margin-bottom: 10px;
        font-size: 1.2em;
      }

      .description .info-value {
        line-height: 1.6;
        color: #c0c0c0;
      }

      @media (max-width: 768px) {
        .book-content {
          flex-direction: column;
          padding: 20px;
        }

        h1 {
          font-size: 1.8em;
        }

        .info-label {
          display: block;
          margin-bottom: 5px;
        }

        .info-value {
          display: block;
        }
      }
    </style>
  </body>
  <body>
    <div class="container">
      <a href="/" class="back-button">← Back to Home</a>

      <div class="book-content">
        <div class="book-image-section">
          <% if (book.picture) { %>
            <img src="<%= book.picture %>" alt="<%= book.title %>" />
          <% } else { %>
            <img src="/images/default-book.jpg" alt="Default book cover" />
          <% } %>
        </div>

        <div class="book-info-section">
          <h1><%= book.title %></h1>

          <div class="info-group">
            <span class="info-label"> Author:</span>
            <span class="info-value"><%= book.author %></span>
          </div>

          <div class="info-group">
            <span class="info-label"> Genre:</span>
            <span class="info-value"><%= book.genre %></span>
          </div>

          <div class="info-group">
            <span class="info-label">Pages:</span>
            <span class="info-value"><%= book.numOfPages %></span>
          </div>

          <div class="description">
            <div class="info-label"> Description:</div>
            <div class="info-value"><%= book.description %></div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
