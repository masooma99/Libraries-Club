<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <div class="head">
<h1> Libraries Club</h1>
<a href="/home">Home</a>
</div>
   <h2><%= book.title %></h2>
<p>ID: <%= book._id %></p>
<p>Author: <%= book.author %></p>
<p>Description: <%= book.description %></p>

<% if(user._id.toString() === book.author._id.toString()) { %>
  <form action="/auth/books/<%= book._id %>/edit">
    <button>Edit</button>
  </form>
  <form action="/auth/books/<%= book._id %>?_method=DELETE" method="POST">
    <button type="submit">Delete</button>
  </form>
<% } %>
</form>




  </body>
</html>
