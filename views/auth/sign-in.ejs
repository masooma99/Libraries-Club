<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <h1>Welcome to libraries Club</h1>
    <h2>login</h2>
    <form action="/auth/sign-in" method="POST">
      <div class="input-box">
        <input type="email" name="email" placeholder="Email" required />
      </div>
      <div class="password">
        <input
          type="password"
          name="password"
          placeholder="Password"
          required
        />
      </div>
      <button type="submit">Sign In</button>

      <h4>Don't have an account? <a href="/auth/sign-up">Register</a>.</h4>
    </form>
  </body>
</html>
