<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= libraryDetails.user.username %> - Libraries Club</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #2c3e50 0%, #000000 100%);
      min-height: 100vh;
      padding: 20px;
    }

    .head {
      text-align: center;
      margin-bottom: 30px;
    }

    .head h1 {
      color: white;
      font-size: 2.5rem;
      margin-bottom: 20px;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .head a {
      display: inline-block;
      color: white;
      text-decoration: none;
      background: #ff6b6b;
      padding: 10px 25px;
      border-radius: 25px;
      font-weight: bold;
      transition: all 0.3s ease;
    }

    .head a:hover {
      background: #ff5252;
      transform: translateY(-2px);
    }

    /* Profile Header */
    .profile-header {
      background: white;
      border-radius: 15px;
      padding: 30px;
      text-align: center;
      max-width: 600px;
      margin: 0 auto 30px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .profile-header img {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid #ff6b6b;
      margin-bottom: 15px;
    }

    .profile-header h2 {
      color: #333;
      font-size: 28px;
      margin-bottom: 15px;
    }

    .profile-header .add-book-btn {
      display: inline-block;
      background: linear-gradient(135deg, #ff6b6b, #ff5252);
      color: white;
      text-decoration: none;
      padding: 10px 25px;
      border-radius: 25px;
      font-weight: bold;
      transition: transform 0.3s;
    }

    .profile-header .add-book-btn:hover {
      transform: translateY(-2px);
    }

    /* Section Titles */
    .section-title {
      text-align: center;
      color: white;
      font-size: 2rem;
      margin: 40px 0 20px;
      position: relative;
    }

    .section-title:after {
      content: '';
      position: absolute;
      bottom: -10px;
      left: 50%;
      transform: translateX(-50%);
      width: 80px;
      height: 3px;
      background: #ff6b6b;
      border-radius: 2px;
    }

    /* Books Grid - Titles Only */
    .titles-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 20px;
      max-width: 1200px;
      margin: 30px auto;
      padding: 0 20px;
    }

    .title-card {
      background: white;
      padding: 20px;
      border-radius: 10px;
      text-align: center;
      box-shadow: 0 5px 15px rgba(0,0,0,0.2);
      transition: all 0.3s ease;
    }

    .title-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

    .title-card h3 {
      color: #333;
      font-size: 18px;
    }

    /* Books Grid - With Images */
    .books-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 25px;
      max-width: 1200px;
      margin: 30px auto;
      padding: 0 20px;
    }

    .book-card {
      background: white;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 5px 15px rgba(0,0,0,0.2);
      transition: all 0.3s ease;
    }

    .book-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

    .book-card a {
      text-decoration: none;
    }

    .book-card img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    .book-card h3 {
      padding: 15px;
      text-align: center;
      color: #333;
    }

    .review-link {
      display: block;
      margin: 10px 15px 15px;
      padding: 10px;
      background: linear-gradient(135deg, #ff6b6b, #ff5252);
      color: white;
      text-align: center;
      border-radius: 25px;
      font-weight: bold;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .review-link:hover {
      transform: translateY(-2px);
    }

    /* Action Buttons */
    .action-buttons {
      text-align: center;
      margin: 30px auto;
      display: flex;
      justify-content: center;
      gap: 15px;
      flex-wrap: wrap;
    }

    .sign-out-btn {
      display: inline-block;
      background: #e74c3c;
      color: white;
      text-decoration: none;
      padding: 10px 25px;
      border-radius: 25px;
      font-weight: bold;
      transition: all 0.3s ease;
    }

    .sign-out-btn:hover {
      background: #c0392b;
      transform: translateY(-2px);
    }

    .update-password-btn {
      display: inline-block;
      background: #f39c12;
      color: white;
      text-decoration: none;
      padding: 10px 25px;
      border-radius: 25px;
      font-weight: bold;
      transition: all 0.3s ease;
    }

    .update-password-btn:hover {
      background: #e67e22;
      transform: translateY(-2px);
    }

    /* Book IDs Section */
    .ids-section {
      background: rgba(255,255,255,0.1);
      border-radius: 10px;
      padding: 20px;
      max-width: 1200px;
      margin: 40px auto;
    }

    .ids-section a {
      display: inline-block;
      background: rgba(255,255,255,0.2);
      color: white;
      text-decoration: none;
      padding: 8px 15px;
      margin: 5px;
      border-radius: 5px;
      font-size: 12px;
      font-family: monospace;
      transition: all 0.3s ease;
    }

    .ids-section a:hover {
      background: rgba(255,255,255,0.3);
      transform: translateY(-2px);
    }

    @media (max-width: 768px) {
      .head h1 {
        font-size: 1.8rem;
      }

      .profile-header {
        padding: 20px;
        margin: 0 15px 30px;
      }

      .profile-header img {
        width: 100px;
        height: 100px;
      }

      .profile-header h2 {
        font-size: 22px;
      }

      .section-title {
        font-size: 1.5rem;
      }

      .titles-grid {
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      }

      .books-grid {
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      }
    }
  </style>
</head>
<body>
  <div class="head">
    <h1> Libraries Club</h1>
    <a href="/"> Home</a>
  </div>

  <div class="profile-header">
    <img src="<%= libraryDetails.user.picture %>" alt="Profile Picture">
    <h2><%= libraryDetails.user.username %></h2>
    <% if(libraryDetails.user.typeOfUser === "Library") { %>
      <a href="/books/create" class="add-book-btn"> Add Book</a>
    <% } %>
  </div>

  <h1 class="section-title"> Books I Added</h1>



 <div class="books-grid">
    <% for(let i = 0; i < libraryDetails.userBooks.length; i++) { %>
      <div class="book-card">
        <a href="/title/<%= libraryDetails.userBooks[i]._id %>">
          <img src="<%= libraryDetails.userBooks[i].picture %>" alt="<%= libraryDetails.userBooks[i].title %>">
          <h3><%= libraryDetails.userBooks[i].title %></h3>
        </a>

        <a href="/reviews/<%= libraryDetails.userBooks[i]._id %>" class="review-link"> Add Review</a>
      </div>
    <% } %>
  </div>



  <% if (libraryDetails.user.typeOfUser === "Library") { %>
    <div class="action-buttons">
      <a href="/auth/sign-out" class="sign-out-btn"> Sign Out</a>
      <a href="/auth/<%= libraryDetails.user._id %>/update-password" class="update-password-btn"> Update Password</a>
    </div>
  <% } %>
</body>
</html>
