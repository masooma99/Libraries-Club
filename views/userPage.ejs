<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= libraryDetails.user.username %></title>
</head>
<body>
  <header>
    <img src="<%= libraryDetails.user.picture %>" alt="Profile Picture" height="180px" width="180px">
    <h2><%= libraryDetails.user.username %></h2>

    <% if (libraryDetails.user.typeOfUser === "Library") { %>
      <a href="/books/create">Add Book</a>
      <a href="/auth/sign-out">sign out</a>
      <div>
        <a href="<%= `/auth/${user._id}/update-password` %>">Update Password</a>
      </div>
    <% } %>
  </header>
  <section>
    <%for(let i =0; i<libraryDetails.userBooks.length; i++){%>
      <hr>
      <a href="/users/<%=libraryDetails.userBooks[i]._id%>">
        <div>
          <h3><%= libraryDetails.userBooks[i].title%></h3>
          <img src="<%=libraryDetails.userBooks[i].picture%> " alt="book image" height="80px" width="80px">
        </div>
      </a>
      <a href="/reviews/<%=libraryDetails.userBooks[i]._id%>">Add review</a>
    <%}%>
  </section>
</body>
</html>

