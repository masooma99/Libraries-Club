<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= libraryDetails.user.username %></title>
</head>
<body>
  <header>
    <img src="<%= libraryDetails.user.picture %>" alt="Profile Picture">
    <h2><%= libraryDetails.user.username %></h2>

    <% if (libraryDetails.user.typeOfUser === "Library") { %>
      <a href="/books/create">Add Book</a>
      <div>
        <a href="<%= `/auth/${user._id}/update-password` %>">Update Password</a>
      </div>
    <% } %>
  </header>
  <section>
    <%for(let i =0; i<libraryDetails.userBooks.length; i++){%>
      <hr>
      <a href="/users/<%=libraryDetails.userBooks[i]._id%>">
        <div>
          <h3><%= libraryDetails.userBooks[i].title%></h3>
          <img src="<%=libraryDetails.userBooks[i].picture%> " alt="book image" height="80px" width="80px">
        </div>
      </a>
      <a href="/reviews/<%=libraryDetails.userBooks[i]._id%>">Add review</a>
    <%}%>
  </section>

   <section>
  <% for(let i = 0; i < libraryDetails.userBooks.length; i++) {
       const book = libraryDetails.userBooks[i];
       if(book && book._id) { %>
   <a href="/auth/books/<%= book._id %>">
      <div>
        <h3><%= book._id %></h3>
      </div>
    </a>
  <% } } %>
</section>

<% if (user._id === book.author._id.toString()) { %>

<form action="/book/<%= book._id %>/edit">
  <button>Edit</button>
</form>

<form action="/book/<%= recipe._id %>?_method=DELETE" method="POST">
  <button type="submit">Delete</button>
</form>

<% } %>


</body>
</html>

